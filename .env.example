# Copy this file to .env.local and fill in your Supabase project's values
# (Project Settings -> API in the Supabase dashboard).
#
# If you leave these blank, the app falls back to storing responses in the
# browser's localStorage - fine for trying it out locally, but the form and
# the dashboard will only see data from their own browser. Set these to
# actually funnel visitor submissions into one shared place the dashboard
# can read from.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
